# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_db

# Better Auth (required — generate secret: openssl rand -base64 32)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://127.0.0.1:3001
BETTER_AUTH_TRUSTED_ORIGINS=http://127.0.0.1:3001,http://localhost:3001
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3001

# Legacy bootstrap admin (scripts until Better Auth seed is added)
AUTH_ADMIN_EMAIL=admin@example.com
AUTH_ADMIN_PASSWORD=ChangeMe123!
AUTH_ADMIN_NAME=Project Admin
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PHONE_NUMBER=0000000000

# Playwright E2E (defaults for local dev on port 3001)
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3001
PLAYWRIGHT_ADMIN_EMAIL=admin@example.com
PLAYWRIGHT_ADMIN_PASSWORD=ChangeMe123!