# =============================================================================
# Transit Ops — environment template
# =============================================================================
# Copy this file for local work:
#   cp .env.example .env
#   # optional overrides (gitignored): cp .env.example .env.local
#
# Bun loads `.env` automatically for `bun run …`. Playwright also merges
# `.env` then `.env.local` (local wins). Never commit real secrets.
#
# Legend:
#   [required]  — app / scripts fail without a real value
#   [seed]      — bootstrap scripts (db:seed, auth:register-admin)
#   [auth]      — required when Better Auth is wired (fill now to stay aligned)
#   [upload]    — document upload policy (ADR-040); safe defaults
#   [e2e]       — Playwright
# =============================================================================

# -----------------------------------------------------------------------------
# Database [required]
# -----------------------------------------------------------------------------
# Local Postgres example:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/transit_ops
# Neon / managed example (use pooler URL + sslmode=require):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
DATABASE_URL=

# -----------------------------------------------------------------------------
# App URL [required for auth cookies / absolute links]
# -----------------------------------------------------------------------------
# Keep these in sync with the port you actually run (default dev/e2e: 3001).
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3001

# -----------------------------------------------------------------------------
# Better Auth [auth] — required for session-backed domain APIs (vehicles, …)
# Full login UX / lockout polish is ODO-20; session getSession is already wired.
# -----------------------------------------------------------------------------
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public origin Better Auth uses for callbacks / cookies (same origin as app).
BETTER_AUTH_URL=http://127.0.0.1:3001

# Comma-separated allowed origins (dev hostnames you actually use).
BETTER_AUTH_TRUSTED_ORIGINS=http://127.0.0.1:3001,http://localhost:3001

# -----------------------------------------------------------------------------
# Bootstrap / seed users [seed]
# -----------------------------------------------------------------------------
# Used by `bun run db:seed`, `auth:register-admin`, `auth:remove-admin`.
# Seeds a fleet_manager into Better Auth tables (user + credential account).
AUTH_ADMIN_EMAIL=admin@example.com
AUTH_ADMIN_PASSWORD=ChangeMe123!
AUTH_ADMIN_NAME=Project Admin
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PHONE_NUMBER=0000000000

# Optional: extra role seeds when multi-user seed script is added (docs §2.11).
# Leave blank until that script exists; names reserved for alignment.
# AUTH_DISPATCHER_EMAIL=dispatcher@example.com
# AUTH_DISPATCHER_PASSWORD=ChangeMe123!
# AUTH_SAFETY_EMAIL=safety@example.com
# AUTH_SAFETY_PASSWORD=ChangeMe123!
# AUTH_FINANCE_EMAIL=finance@example.com
# AUTH_FINANCE_PASSWORD=ChangeMe123!

# -----------------------------------------------------------------------------
# Document uploads [upload] — ADR-040
# -----------------------------------------------------------------------------
# Max file size in bytes (default 5 MiB).
UPLOAD_MAX_BYTES=5242880

# Comma-separated MIME allow-list, or `*` for all types.
UPLOAD_ALLOWED_MIME=*

# Optional root for stored files (relative to project or absolute). App wiring TBD.
# UPLOAD_STORAGE_DIR=uploads

# -----------------------------------------------------------------------------
# Playwright E2E [e2e]
# -----------------------------------------------------------------------------
# Must match the port the test webServer uses (see playwright.config.ts).
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3001

# Prefer email once Better Auth UI is live; username kept for transitional specs.
PLAYWRIGHT_ADMIN_EMAIL=admin@example.com
PLAYWRIGHT_ADMIN_USERNAME=admin
PLAYWRIGHT_ADMIN_PASSWORD=ChangeMe123!

# -----------------------------------------------------------------------------
# Optional / environment flags
# -----------------------------------------------------------------------------
# NODE_ENV=development
# CI=1
