# =============================================================================
# Transit Ops — environment template
# =============================================================================
# Copy this file for local work:
#   cp .env.example .env
#   # optional overrides (gitignored): cp .env.example .env.local
#
# Bun loads `.env` automatically for `bun run …`. Playwright also merges
# `.env` then `.env.local` (local wins). Never commit real secrets.
#
# Legend:
#   [required]  — app / scripts fail without a real value
#   [seed]      — bootstrap scripts (db:seed, auth:register-admin)
#   [auth]      — required when Better Auth is wired (fill now to stay aligned)
#   [upload]    — document upload policy (ADR-040); safe defaults
#   [e2e]       — Playwright
# =============================================================================

# -----------------------------------------------------------------------------
# Database [required]
# -----------------------------------------------------------------------------
# Local Postgres example:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/transit_ops
# Neon / managed example (use pooler URL + sslmode=require):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
DATABASE_URL=

# -----------------------------------------------------------------------------
# App URL [required for auth cookies / absolute links]
# -----------------------------------------------------------------------------
# Keep these in sync with the port you actually run (default dev/e2e: 3001).
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3001

# -----------------------------------------------------------------------------
# Better Auth [auth] — required for session-backed domain APIs (vehicles, …)
# Full login UX / lockout polish is ODO-20; session getSession is already wired.
# -----------------------------------------------------------------------------
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public origin Better Auth uses for callbacks / cookies (same origin as app).
BETTER_AUTH_URL=http://127.0.0.1:3001

# Comma-separated allowed origins (dev hostnames you actually use).
BETTER_AUTH_TRUSTED_ORIGINS=http://127.0.0.1:3001,http://localhost:3001

# Login lockout (Better Auth rate limit on /sign-in/email). Default on when unset.
# Playwright sets this to false so intentional failure cases do not lock the shared browser IP.
# AUTH_RATE_LIMIT_ENABLED=false

# -----------------------------------------------------------------------------
# Bootstrap / seed users [seed] — demo logins (local only; also in README)
# -----------------------------------------------------------------------------
# Used by `bun run db:seed`, `auth:register-admin`, `auth:remove-admin`.
# All demo users share AUTH_ADMIN_PASSWORD after seed.
#
# | Role               | Email                     | Password | Role dropdown      |
# | ------------------ | ------------------------- | -------- | ------------------ |
# | Fleet Manager      | admin@example.com         | password | fleet_manager      |
# | Financial Analyst  | finance@example.com       | password | financial_analyst  |
# | Safety Officer     | safety@example.com        | password | safety_officer     |
# | Dispatcher         | dispatcher@example.com    | password | dispatcher         |
AUTH_ADMIN_EMAIL=admin@example.com
AUTH_ADMIN_PASSWORD=password
AUTH_ADMIN_NAME=Project Admin
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PHONE_NUMBER=0000000000

# Explicit demo accounts (seeded by db:seed; same password as AUTH_ADMIN_PASSWORD)
AUTH_FINANCE_EMAIL=finance@example.com
AUTH_FINANCE_PASSWORD=password
AUTH_SAFETY_EMAIL=safety@example.com
AUTH_SAFETY_PASSWORD=password
AUTH_DISPATCHER_EMAIL=dispatcher@example.com
AUTH_DISPATCHER_PASSWORD=password

# -----------------------------------------------------------------------------
# Document uploads [upload] — ADR-040
# -----------------------------------------------------------------------------
# Max file size in bytes (default 5 MiB).
UPLOAD_MAX_BYTES=5242880

# Comma-separated MIME allow-list, or `*` for all types.
UPLOAD_ALLOWED_MIME=*

# Optional root for stored files (relative to project or absolute). App wiring TBD.
# UPLOAD_STORAGE_DIR=uploads

# -----------------------------------------------------------------------------
# Playwright E2E [e2e]
# -----------------------------------------------------------------------------
# Must match the port the test webServer uses (see playwright.config.ts).
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3001

# Prefer email once Better Auth UI is live; username kept for transitional specs.
PLAYWRIGHT_ADMIN_EMAIL=admin@example.com
PLAYWRIGHT_ADMIN_USERNAME=admin
PLAYWRIGHT_ADMIN_PASSWORD=password

# -----------------------------------------------------------------------------
# Resend transactional email [email] — no nodemailer/SMTP
# Shared client: src/lib/email/_lib/resend-client.ts
# Full developer steps (dashboard + testing): docs/resend-setup.md
# Testing without a domain: From = onboarding@resend.dev; To = your Resend signup email only
# -----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=onboarding@resend.dev
EMAIL_FROM_NAME=TransitOps
# Smoke test: bun run email:test you@your-resend-signup-email.com

# -----------------------------------------------------------------------------
# Notifications / license-expiry cron [notifications] — ODO-40
# -----------------------------------------------------------------------------
# Master switch for enqueue/drain scripts and the optional worker.
NOTIFICATIONS_ENABLED=true

# Exact day-before-expiry thresholds (comma-separated). Daily job matches these.
NOTIFICATIONS_REMINDER_DAYS=30,14,7

# UTC wall-clock for scheduled runs (HH:MM). Wire OS cron near this time:
#   0 9 * * * cd /path/to/app && bun run notifications:run
# Or run: bun run notifications:worker
NOTIFICATIONS_SCHEDULE_TIME=09:00
NOTIFICATIONS_TIMEZONE=UTC

# Used when a driver has no linked user.email (falls back to AUTH_ADMIN_EMAIL if unset).
NOTIFICATIONS_FALLBACK_EMAIL=admin@example.com

# log = print email to stdout and mark sent (local/dev)
# resend = shared Resend client (requires RESEND_API_KEY above)
NOTIFICATIONS_MAIL_MODE=log
# Optional From override for notification jobs; defaults to EMAIL_FROM_NAME <EMAIL_FROM_ADDRESS>
# NOTIFICATIONS_FROM_EMAIL=TransitOps <noreply@example.com>

# -----------------------------------------------------------------------------
# Optional / environment flags
# -----------------------------------------------------------------------------
# NODE_ENV=development
# CI=1
