{
  "name": "transit-ops",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src --no-warn-ignored",
    "lint:fix": "eslint src --fix --no-warn-ignored",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "bun run lint && bun run build",
    "prepare": "husky",
    "auth:hash": "bun scripts/generate-password-hash.ts",
    "auth:register-admin": "bun scripts/register-admin.ts",
    "auth:remove-admin": "bun scripts/remove-admin.ts",
    "db:connect": "bun scripts/db-test-connection.ts",
    "db:export": "bun scripts/db-export.ts",
    "db:export:sql": "bun scripts/db-export.ts --format=plain",
    "db:export:custom": "bun scripts/db-export.ts --format=custom",
    "db:verify": "bun scripts/db-verify-schema.ts",
    "db:status": "bun scripts/db-status.ts",
    "db:seed": "bun scripts/db-seed.ts",
    "db:reset": "bun scripts/db-reset.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "@elysiajs/eden": "^1.4.9",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "effect": "^3.21.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "10.3.0",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "husky": "9.1.7",
    "lint-staged": "17.0.2",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "@types/bun": "^1.3.13",
    "drizzle-kit": "^0.31.10"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,css,scss,yml,yaml}": [
      "prettier --write --ignore-unknown"
    ],
    "src/**/*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix --no-warn-ignored"
    ]
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
